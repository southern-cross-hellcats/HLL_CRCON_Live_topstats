# Sample environment configuration for the live_topstats plugin.
# Copy the variables you want into your CRCON .env file and adjust as needed.

LIVE_TOPSTATS_LANG=0
LIVE_TOPSTATS_ENABLE_ON_SERVERS=["1"]
LIVE_TOPSTATS_OFFENSEDEFENSE_RATIO=1.75
LIVE_TOPSTATS_COMBATSUPPORT_RATIO=1.75

LIVE_TOPSTATS_CHAT_COMMAND=!top
LIVE_TOPSTATS_TOPS_CHAT=3
LIVE_TOPSTATS_TOPS_CHAT_DETAIL_SQUADS=1

LIVE_TOPSTATS_TOPS_MATCHEND=3
LIVE_TOPSTATS_TOPS_MATCHEND_DETAIL_SQUADS=1
LIVE_TOPSTATS_VIP_WINNERS=1
LIVE_TOPSTATS_VIP_COMMANDER_MIN_PLAYTIME_MINS=20
LIVE_TOPSTATS_VIP_COMMANDER_MIN_SUPPORT_SCORE=1000
LIVE_TOPSTATS_SEED_LIMIT=40
LIVE_TOPSTATS_VIP_HOURS=24
LIVE_TOPSTATS_SCORE_PER_MINUTE=20

LIVE_TOPSTATS_LOCAL_TIMEZONE=America/Argentina/Buenos_Aires

# JSON list of [webhook_url, enabled] pairs, one entry per CRCON server.
LIVE_TOPSTATS_SERVER_CONFIG=[["https://discord.com/api/webhooks/REAL_SERVER_1",true],["https://discord.com/api/webhooks/REAL_SERVER_2",false]]

LIVE_TOPSTATS_DISCORD_EMBED_AUTHOR_ICON_URL=https://cdn.discordapp.com/icons/316459644476456962/73a28de670af9e6569f231c9385398f3.webp?size=64
LIVE_TOPSTATS_BOT_NAME=CRCON_top_stats_of_the_game
